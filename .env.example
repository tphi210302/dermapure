# ─── Copy this file to .env and fill in real values ─────────
# ─── .env is gitignored; never commit secrets                ─

NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────────
MONGO_URI=mongodb://mongodb:27017/pharma-shop

# ─── JWT (CHANGE THESE — generate 32+ char random strings) ─
# Quick generate: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_to_long_random_string_min_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=CHANGE_ME_to_another_long_random_string
JWT_REFRESH_EXPIRES_IN=30d

# ─── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=1000

# ─── CORS ─────────────────────────────────────────────────
CLIENT_ORIGIN=http://localhost:3000,http://localhost:3001

# ─── Admin Seed (first-time install) ──────────────────────
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=CHANGE_ME_strong_password

# ─── Frontend ─────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:5000
